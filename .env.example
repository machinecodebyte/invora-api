APP_NAME=Invora
APP_TAGLINE="Predict - Optimize - Replenish"
APP_ENV=local
COMPOSE_PROJECT_NAME=invora
DEBUG=true
API_V1_PREFIX=/api/v1
API_HOST=127.0.0.1
API_PORT=8000
POSTGRES_HOST_PORT=5432
POSTGRES_DB=invora
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:${POSTGRES_HOST_PORT}/invora
DOCKER_DATABASE_URL=postgresql+asyncpg://postgres:postgres@invora-postgres:5432/invora
REDIS_URL=redis://localhost:56379/0
DOCKER_REDIS_URL=redis://invora-redis:6379/0
RQ_DEFAULT_QUEUE=invora-default
RQ_FORECAST_QUEUE=invora-forecasting
RQ_JOB_TIMEOUT_SECONDS=1800
RQ_MAX_RETRIES=3
RQ_RETRY_INTERVAL_SECONDS=30
RQ_RESULT_TTL_SECONDS=86400
RQ_FAILURE_TTL_SECONDS=604800
RQ_WORKER_NAME_PREFIX=invora-worker
WORKER_ENABLED=true
REDIS_HOST_PORT=56379
BACKEND_HOST_PORT=8000
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
LOG_LEVEL=INFO
JWT_SECRET_KEY=replace-with-a-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14
